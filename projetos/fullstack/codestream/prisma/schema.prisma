generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Room {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique @default(cuid())
  language    String     @default("typescript")
  code        String     @default("") @db.Text
  isPublic    Boolean    @default(true)
  maxMembers  Int        @default(10)
  ownerId     String?
  expiresAt   DateTime?

  members   RoomMember[]
  snapshots CodeSnapshot[]
  messages  Message[]
  executions ExecutionResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model RoomMember {
  id       String @id @default(cuid())
  roomId   String
  userId   String   // Clerk ID or anonymous ID
  username String
  color    String   // hex color for cursor
  isGuest  Boolean  @default(false)
  joinedAt DateTime @default(now())
  leftAt   DateTime?

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
}

model CodeSnapshot {
  id         String   @id @default(cuid())
  roomId     String
  code       String   @db.Text
  language   String
  savedById  String
  savedByName String
  createdAt  DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
}

model Message {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  username  String
  text      String
  createdAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
}

model ExecutionResult {
  id         String   @id @default(cuid())
  roomId     String
  language   String
  code       String   @db.Text
  stdout     String?  @db.Text
  stderr     String?  @db.Text
  exitCode   Int
  timeMs     Int
  memoryKb   Int
  executedBy String
  executedAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
}
